// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider   = "postgresql"
  schemas    = ["vibe_stack"]
  extensions = [citext]
}

generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["fullTextSearchPostgres", "multiSchema", "postgresqlExtensions"]
  engineType      = "client"
}

generator zod {
  provider = "prisma-zod-generator"
  output   = "../src/generated/zod"
}

generator kysely {
  provider = "prisma-kysely"

  // Optionally provide a destination directory for the generated file
  // and a filename of your choice
  output       = "../src/generated/kysely"
  fileName     = "types.ts"
  // Optionally generate runtime enums to a separate file
  enumFileName = "enums.ts"
  readOnlyIds  = true
}

model VerificationToken {
  identifier String   @id
  token      String
  attempts   Int      @default(0)
  issuedAt   DateTime @default(now()) @db.Timestamptz(3)

  @@schema("vibe_stack")
}

model User {
  id            String              @id @default(cuid(2))
  name          String?             @unique @db.Citext
  email         String?             @unique
  image         String?
  avatarUrl     String?             @map("avatar_url")
  roleId        String              @map("role_id")
  role          Role                @relation(fields: [roleId], references: [id], onDelete: Restrict)
  accounts      Account[]
  passkeys      Passkey[]
  notifications Notification[]
  files         File[]
  auditLogs     AuditLog[]
  resetTokens   PasskeyResetToken[] @relation("ResetTokenSubject")
  issuedResets  PasskeyResetToken[] @relation("ResetTokenIssuer")
  issuedInvites Invite[]            @relation("InviteIssuer")
  claimedInvite Invite?             @relation("InviteClaimer")
  apiTokens     ApiToken[]
  systemMessageUpdates SystemMessage[]

  lastLogin DateTime? @db.Timestamptz(3)
  createdAt DateTime  @default(now()) @db.Timestamptz(3)

  @@index([roleId])
  @@schema("vibe_stack")
}

/// Application role. Capabilities are stored as a string array of dotted
/// codes (e.g. "file.upload", "user.delete") and checked against the
/// canonical catalogue in `apps/web/src/server/modules/rbac/capabilities.ts`.
/// `isSystem` flags the seeded Admin/User roles so they can't be deleted
/// (their capability sets are still editable).
model Role {
  id           String   @id
  name         String   @unique @db.Citext
  description  String?
  isSystem     Boolean  @default(false) @map("is_system")
  capabilities String[] @default([])
  createdAt    DateTime @default(now()) @db.Timestamptz(3)
  updatedAt    DateTime @updatedAt @db.Timestamptz(3)
  users        User[]
  invites      Invite[]

  @@schema("vibe_stack")
}

model Account {
  id                String @id @default(cuid(2))
  provider          String
  providerAccountId String

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@schema("vibe_stack")
}

model Passkey {
  id                   String   @id @default(cuid(2))
  userId               String   @map("user_id")
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentialId         String   @unique @map("credential_id")
  credentialPublicKey  Bytes    @map("credential_public_key")
  counter              BigInt
  credentialDeviceType String   @map("credential_device_type")
  credentialBackedUp   Boolean  @map("credential_backed_up")
  transports           String[] @default([])
  name                 String?
  createdAt            DateTime @default(now()) @db.Timestamptz(3)
  lastUsedAt           DateTime @default(now()) @db.Timestamptz(3)

  @@index([userId])
  @@schema("vibe_stack")
}

model PasskeyChallenge {
  id        String   @id @default(cuid(2))
  userId    String?  @map("user_id")
  challenge String   @unique
  expiresAt DateTime @db.Timestamptz(3)
  createdAt DateTime @default(now()) @db.Timestamptz(3)

  @@index([userId])
  @@schema("vibe_stack")
}

model PasskeyResetToken {
  id         String    @id @default(cuid(2))
  token      String    @unique
  userId     String    @map("user_id")
  user       User      @relation("ResetTokenSubject", fields: [userId], references: [id], onDelete: Cascade)
  issuedById String    @map("issued_by_id")
  issuedBy   User      @relation("ResetTokenIssuer", fields: [issuedById], references: [id])
  expiresAt  DateTime? @map("expires_at") @db.Timestamptz(3)
  consumedAt DateTime? @map("consumed_at") @db.Timestamptz(3)
  createdAt  DateTime  @default(now()) @db.Timestamptz(3)

  @@index([userId])
  @@index([issuedById])
  @@schema("vibe_stack")
}

/// One-time invite link issued by an admin so a recipient can self-register
/// a passkey and land in the app under a pre-assigned role. Mirrors the
/// PasskeyResetToken shape: token (unique), expiry, single-use consumedAt.
/// `roleId` is the role the new user will be created with on claim. `email`
/// and `name` are optional pre-fills shown to the issuer/recipient — the
/// recipient picks their final account name during the passkey ceremony.
/// `claimedByUserId` is set when the invite is consumed and FKs to the
/// newly-created user (one-to-one).
model Invite {
  id              String    @id @default(cuid(2))
  token           String    @unique
  email           String?
  name            String?
  roleId          String    @map("role_id")
  role            Role      @relation(fields: [roleId], references: [id], onDelete: Restrict)
  issuedById      String    @map("issued_by_id")
  issuedBy        User      @relation("InviteIssuer", fields: [issuedById], references: [id])
  claimedByUserId String?   @unique @map("claimed_by_user_id")
  claimedBy       User?     @relation("InviteClaimer", fields: [claimedByUserId], references: [id], onDelete: SetNull)
  expiresAt       DateTime? @map("expires_at") @db.Timestamptz(3)
  consumedAt      DateTime? @map("consumed_at") @db.Timestamptz(3)
  revokedAt       DateTime? @map("revoked_at") @db.Timestamptz(3)
  createdAt       DateTime  @default(now()) @db.Timestamptz(3)

  @@index([issuedById])
  @@index([roleId])
  @@schema("vibe_stack")
}

model AuditLog {
  id        String   @id @default(cuid(2))
  userId    String?  @map("user_id")
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  metadata  Json?
  ip        String?
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @db.Timestamptz(3)

  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@schema("vibe_stack")
}

model Notification {
  id        String    @id @default(cuid(2))
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String?
  href      String?
  readAt    DateTime? @map("read_at") @db.Timestamptz(3)
  createdAt DateTime  @default(now()) @db.Timestamptz(3)

  @@index([userId, readAt])
  @@index([userId, createdAt])
  @@schema("vibe_stack")
}

model File {
  id        String   @id @default(cuid(2))
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  url       String
  pathname  String   @unique
  filename  String
  mimeType  String   @map("mime_type")
  size      Int
  createdAt DateTime @default(now()) @db.Timestamptz(3)

  // Generated tsvector column populated by Postgres from filename; queried
  // via Kysely + raw `tsquery`. Prisma doesn't manage it (Unsupported type).
  searchable Unsupported("tsvector")?

  @@index([userId, createdAt])
  @@schema("vibe_stack")
}

/// Self-hosted feature flag. `enabled` is the master switch; when on,
/// `allowedUserIds` always-on overrides the percent rollout. The percent
/// rollout uses a stable SHA-256 hash of `${key}:${userId}` so a given user
/// always falls in the same bucket for a given flag — see
/// `apps/web/src/server/modules/feature-flag/feature-flag.service.ts`.
model FeatureFlag {
  key            String   @id @db.VarChar(64)
  name           String
  description    String?
  enabled        Boolean  @default(false)
  rolloutPercent Int      @default(0) @map("rollout_percent")
  allowedUserIds String[] @map("allowed_user_ids")
  createdAt      DateTime @default(now()) @db.Timestamptz(3)
  updatedAt      DateTime @updatedAt @db.Timestamptz(3)

  @@schema("vibe_stack")
}

/// Singleton row holding the app-wide system message banner. There is at
/// most one row, identified by the literal id "singleton" so admin updates
/// are a simple upsert without a count query.
///
/// `enabled` is the master switch — banner only renders when true.
/// `severity` controls the visual treatment (info / warning / critical).
/// `updatedById` is `SetNull` so deleting an admin doesn't wipe the row.
model SystemMessage {
  id          String                @id @default("singleton")
  enabled     Boolean               @default(false)
  message     String
  severity    SystemMessageSeverity @default(INFO)
  updatedAt   DateTime              @updatedAt @db.Timestamptz(3)
  updatedById String?               @map("updated_by_id")
  updatedBy   User?                 @relation(fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([updatedById])
  @@schema("vibe_stack")
}

enum SystemMessageSeverity {
  INFO
  WARNING
  CRITICAL

  @@schema("vibe_stack")
}

/// Personal API token. Stored as the SHA-256 hex of the plaintext (the
/// plaintext only ever appears in the `apiToken.issue` mutation response).
/// `prefix` is the first 8 chars of the plaintext for human-readable display
/// in the settings UI; it is not load-bearing for verification.
model ApiToken {
  id         String    @id @default(cuid(2))
  userId     String    @map("user_id")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  tokenHash  String    @unique @map("token_hash")
  prefix     String
  lastUsedAt DateTime? @map("last_used_at") @db.Timestamptz(3)
  expiresAt  DateTime? @map("expires_at") @db.Timestamptz(3)
  revokedAt  DateTime? @map("revoked_at") @db.Timestamptz(3)
  createdAt  DateTime  @default(now()) @db.Timestamptz(3)

  @@index([userId, revokedAt])
  @@schema("vibe_stack")
}
